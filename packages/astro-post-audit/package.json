{
  "name": "@casoon/astro-post-audit",
  "version": "0.4.0",
  "description": "Astro integration for post-build auditing: SEO, links, and lightweight WCAG checks",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": "./schema.json"
  },
  "scripts": {
    "build": "tsc && npm run generate-schema",
    "generate-schema": "typescript-json-schema tsconfig.json PostAuditOptions --noExtraProps -o schema.json",
    "verify:binary": "node scripts/verify-binary.cjs",
    "test": "tsc && node --test dist/*.test.js",
    "prepublishOnly": "node -e \"require('fs').copyFileSync('../../README.md','README.md')\" && tsc && npm run generate-schema",
    "postinstall": "node bin/install.cjs"
  },
  "files": [
    "bin/install.cjs",
    "bin/run.cjs",
    "dist/",
    "schema.json",
    "README.md"
  ],
  "keywords": [
    "astro",
    "astro-integration",
    "seo",
    "audit",
    "accessibility",
    "static-site",
    "wcag",
    "canonical",
    "links"
  ],
  "author": {
    "name": "Jörn Seidel",
    "email": "info@casoon.de",
    "url": "https://www.casoon.de"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/casoon/astro-post-audit"
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "peerDependencies": {
    "astro": "^5.0.0 || ^6.0.0-beta.0 || ^7.0.0-alpha.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "astro": "^5.0.0",
    "typescript": "^5.9.3",
    "typescript-json-schema": "^0.67.1"
  }
}
