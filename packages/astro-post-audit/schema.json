{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "definitions": {
        "GoLiveConfig": {
            "additionalProperties": false,
            "properties": {
                "enabled": {
                    "default": false,
                    "description": "Enable go-live production gate checks.",
                    "type": "boolean"
                },
                "expectedSite": {
                    "description": "Expected production origin. Auto-detected from Astro's `site` config if not set.\nOnly set this when the go-live target intentionally differs from Astro `site`.",
                    "type": "string"
                },
                "forbiddenDomains": {
                    "description": "Domains that must not appear in canonical URLs, sitemaps, OG tags, or absolute links.",
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                }
            },
            "type": "object"
        },
        "GroupsConfig": {
            "additionalProperties": false,
            "properties": {
                "a11y": {
                    "description": "Enable accessibility rules (a11y, headings, lang attribute).",
                    "enum": [
                        false,
                        true,
                        "warn"
                    ]
                },
                "links": {
                    "description": "Enable link-integrity rules (broken links, fragments, orphan pages).",
                    "enum": [
                        false,
                        true,
                        "warn"
                    ]
                },
                "performance": {
                    "description": "Enable performance rules (image dimensions, hashed filenames, render blocking).",
                    "enum": [
                        false,
                        true,
                        "warn"
                    ]
                },
                "privacy": {
                    "description": "Enable privacy/security rules (third-party domains, SRI, inline scripts).",
                    "enum": [
                        false,
                        true,
                        "warn"
                    ]
                },
                "seo": {
                    "description": "Enable SEO-focused rules (canonical, meta description, OG tags, structured data).",
                    "enum": [
                        false,
                        true,
                        "warn"
                    ]
                }
            },
            "type": "object"
        },
        "Record<string,\"error\"|\"warning\"|\"info\"|\"off\">": {
            "additionalProperties": false,
            "type": "object"
        },
        "ReportsConfig": {
            "additionalProperties": false,
            "properties": {
                "json": {
                    "description": "Write a JSON report to this file path (relative to project root).",
                    "type": "string"
                },
                "markdown": {
                    "description": "Write a Markdown summary report to this file path (relative to project root).",
                    "type": "string"
                },
                "sarif": {
                    "description": "Write a SARIF 2.1.0 report to this file path (relative to project root). For use with GitHub Code Scanning.",
                    "type": "string"
                }
            },
            "type": "object"
        },
        "RulesConfig": {
            "additionalProperties": false,
            "description": "Inline rules config that mirrors the Rust config structure.\nAll sections and fields are optional — only set what you want to override.",
            "properties": {
                "a11y": {
                    "additionalProperties": false,
                    "description": "Accessibility (a11y) heuristics — static checks, no layout computation.",
                    "properties": {
                        "a_accessible_name_required": {
                            "default": true,
                            "description": "`<a>` elements must have an accessible name (text, `aria-label`, or `aria-labelledby`).",
                            "type": "boolean"
                        },
                        "allow_decorative_images": {
                            "default": true,
                            "description": "Allow images with `role=\"presentation\"` or `aria-hidden=\"true\"` to skip `alt`.",
                            "type": "boolean"
                        },
                        "aria_hidden_focusable_check": {
                            "default": true,
                            "description": "Warn if `aria-hidden=\"true\"` is set on a focusable element.",
                            "type": "boolean"
                        },
                        "button_name_required": {
                            "default": true,
                            "description": "`<button>` elements must have an accessible name.",
                            "type": "boolean"
                        },
                        "check_alt_quality": {
                            "default": true,
                            "description": "Flag low-quality `alt` text (file names, placeholder words like \"image\"/\"logo\", too short).",
                            "type": "boolean"
                        },
                        "check_aria_roles": {
                            "default": true,
                            "description": "Validate ARIA `role` values against the WAI-ARIA spec.",
                            "type": "boolean"
                        },
                        "check_duplicate_ids": {
                            "default": true,
                            "description": "Detect duplicate `id` attributes on a page. Duplicate ids break ARIA references.",
                            "type": "boolean"
                        },
                        "check_landmarks": {
                            "default": true,
                            "description": "Check for semantic landmark elements (`<main>`, `<nav>`, `<header>`, `<footer>`).",
                            "type": "boolean"
                        },
                        "img_alt_required": {
                            "default": true,
                            "description": "`<img>` elements must have an `alt` attribute.",
                            "type": "boolean"
                        },
                        "label_for_required": {
                            "default": true,
                            "description": "Form controls must have an associated `<label>`.",
                            "type": "boolean"
                        },
                        "require_skip_link": {
                            "default": false,
                            "description": "Require a skip navigation link (e.g. `<a href=\"#main-content\">`).",
                            "type": "boolean"
                        },
                        "warn_generic_link_text": {
                            "default": true,
                            "description": "Warn on generic link text like \"click here\", \"mehr\", \"weiter\".",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "ai_visibility": {
                    "additionalProperties": false,
                    "default": false,
                    "description": "AI visibility scoring — checks static signals that influence AI search citation probability.",
                    "properties": {
                        "enabled": {
                            "default": false,
                            "description": "Enable AI visibility checks.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "assets": {
                    "additionalProperties": false,
                    "description": "Asset reference and size checks.",
                    "properties": {
                        "check_broken_assets": {
                            "default": false,
                            "description": "Check that `<img>`, `<script>`, `<link>` references resolve to files in `dist/`.",
                            "type": "boolean"
                        },
                        "check_image_dimensions": {
                            "default": false,
                            "description": "Warn if `<img>` is missing `width`/`height` attributes (CLS prevention).",
                            "type": "boolean"
                        },
                        "max_css_size_kb": {
                            "description": "Warn if any CSS file exceeds this size in KB. Off by default.",
                            "type": "number"
                        },
                        "max_image_size_kb": {
                            "description": "Warn if any image file exceeds this size in KB. Off by default.",
                            "type": "number"
                        },
                        "max_js_size_kb": {
                            "description": "Warn if any JS file exceeds this size in KB. Off by default.",
                            "type": "number"
                        },
                        "require_hashed_filenames": {
                            "default": false,
                            "description": "Warn if asset filenames lack a cache-busting hash.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "canonical": {
                    "additionalProperties": false,
                    "description": "Canonical `<link rel=\"canonical\">` tag checks.",
                    "properties": {
                        "absolute": {
                            "default": true,
                            "description": "Canonical URL must be absolute (not relative).",
                            "type": "boolean"
                        },
                        "detect_clusters": {
                            "default": true,
                            "description": "Warn when multiple pages share the same canonical URL (cluster detection).",
                            "type": "boolean"
                        },
                        "require": {
                            "default": true,
                            "description": "Every page must have a canonical tag.",
                            "type": "boolean"
                        },
                        "same_origin": {
                            "default": true,
                            "description": "Canonical must point to the same origin as `site`.",
                            "type": "boolean"
                        },
                        "self_reference": {
                            "default": false,
                            "description": "Canonical must be a self-reference (point to the page itself).",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "content_quality": {
                    "additionalProperties": false,
                    "description": "Duplicate content detection.",
                    "properties": {
                        "detect_duplicate_descriptions": {
                            "default": false,
                            "description": "Warn if multiple pages share the same meta description.",
                            "type": "boolean"
                        },
                        "detect_duplicate_h1": {
                            "default": false,
                            "description": "Warn if multiple pages share the same `<h1>`.",
                            "type": "boolean"
                        },
                        "detect_duplicate_pages": {
                            "default": false,
                            "description": "Warn if pages have identical content (by hash).",
                            "type": "boolean"
                        },
                        "detect_duplicate_titles": {
                            "default": false,
                            "description": "Warn if multiple pages share the same `<title>`.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "content_sync": {
                    "additionalProperties": false,
                    "description": "Cross-check `src/content/` collection items against generated pages.\nRequires the project root, which the integration passes automatically.",
                    "properties": {
                        "enabled": {
                            "default": false,
                            "description": "Warn about content items with no corresponding build page.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "crawl_budget": {
                    "additionalProperties": false,
                    "description": "Crawl budget audit for URL variants, indexability mismatches, and duplicate clusters.",
                    "properties": {
                        "enabled": {
                            "default": false,
                            "description": "Enable crawl budget checks in dist output.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "external_links": {
                    "additionalProperties": false,
                    "description": "External link checking (HEAD requests to verify URLs return 2xx).",
                    "properties": {
                        "allow_domains": {
                            "description": "Only check links to these domains (empty = all).",
                            "items": {
                                "type": "string"
                            },
                            "type": "array"
                        },
                        "block_domains": {
                            "description": "Skip links to these domains.",
                            "items": {
                                "type": "string"
                            },
                            "type": "array"
                        },
                        "enabled": {
                            "default": false,
                            "description": "Enable external link checking.",
                            "type": "boolean"
                        },
                        "fail_on_broken": {
                            "default": false,
                            "description": "Broken external links are errors (not just warnings).",
                            "type": "boolean"
                        },
                        "max_concurrent": {
                            "default": 10,
                            "description": "Maximum concurrent requests.",
                            "type": "number"
                        },
                        "timeout_ms": {
                            "default": 3000,
                            "description": "Timeout per request in milliseconds.",
                            "type": "number"
                        }
                    },
                    "type": "object"
                },
                "filters": {
                    "additionalProperties": false,
                    "description": "File filters — glob patterns to include or exclude pages from all checks.",
                    "properties": {
                        "exclude": {
                            "description": "Skip files matching these glob patterns (e.g. `[\"404.html\", \"drafts/**\"]`).",
                            "items": {
                                "type": "string"
                            },
                            "type": "array"
                        },
                        "include": {
                            "description": "Only check files matching these glob patterns.",
                            "items": {
                                "type": "string"
                            },
                            "type": "array"
                        }
                    },
                    "type": "object"
                },
                "headings": {
                    "additionalProperties": false,
                    "description": "Heading hierarchy checks.",
                    "properties": {
                        "no_skip": {
                            "default": false,
                            "description": "No heading level gaps (e.g. `<h2>` followed by `<h4>`).",
                            "type": "boolean"
                        },
                        "require_h1": {
                            "default": true,
                            "description": "Page must have at least one `<h1>`.",
                            "type": "boolean"
                        },
                        "single_h1": {
                            "default": true,
                            "description": "Only one `<h1>` per page.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "hreflang": {
                    "additionalProperties": false,
                    "description": "Hreflang checks for multilingual sites.",
                    "properties": {
                        "check_hreflang": {
                            "default": false,
                            "description": "Enable hreflang link checks.",
                            "type": "boolean"
                        },
                        "require_reciprocal": {
                            "default": false,
                            "description": "Hreflang links must be reciprocal (A→B and B→A).",
                            "type": "boolean"
                        },
                        "require_self_reference": {
                            "default": false,
                            "description": "Hreflang must include a self-referencing entry.",
                            "type": "boolean"
                        },
                        "require_target_exists": {
                            "default": false,
                            "description": "Warn when an internal hreflang target does not exist in the build.",
                            "type": "boolean"
                        },
                        "require_x_default": {
                            "default": false,
                            "description": "Require an `x-default` hreflang entry.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "html_basics": {
                    "additionalProperties": false,
                    "description": "Basic HTML structure checks.",
                    "properties": {
                        "lang_attr_required": {
                            "default": true,
                            "description": "`<html lang=\"...\">` attribute is required.",
                            "type": "boolean"
                        },
                        "meta_description_max_length": {
                            "default": 160,
                            "description": "Warn if meta description exceeds this character length.",
                            "type": "number"
                        },
                        "meta_description_required": {
                            "default": false,
                            "description": "`<meta name=\"description\">` is required.",
                            "type": "boolean"
                        },
                        "title_max_length": {
                            "default": 60,
                            "description": "Warn if `<title>` exceeds this character length.",
                            "type": "number"
                        },
                        "title_required": {
                            "default": true,
                            "description": "`<title>` tag is required and must be non-empty.",
                            "type": "boolean"
                        },
                        "viewport_required": {
                            "default": true,
                            "description": "`<meta name=\"viewport\">` is required.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "html_validation": {
                    "additionalProperties": false,
                    "description": "Native HTML5 syntax validation using the html5ever tokenizer (offline).",
                    "properties": {
                        "enabled": {
                            "default": false,
                            "description": "Report HTML5 parse/syntax errors.",
                            "type": "boolean"
                        },
                        "max_per_page": {
                            "default": 20,
                            "description": "Maximum distinct syntax errors reported per page.",
                            "type": "number"
                        }
                    },
                    "type": "object"
                },
                "i18n_audit": {
                    "additionalProperties": false,
                    "description": "I18n consistency audit across route locale, lang, hreflang, and canonical signals.",
                    "properties": {
                        "enabled": {
                            "default": false,
                            "description": "Enable i18n consistency checks in dist output.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "images": {
                    "additionalProperties": false,
                    "description": "Image HTML attribute checks for CLS prevention and responsive image best practices.",
                    "properties": {
                        "check_missing_dimensions": {
                            "default": true,
                            "description": "Error if `<img>` is missing both `width` and `height` (causes Cumulative Layout Shift).",
                            "type": "boolean"
                        },
                        "format_hints": {
                            "default": false,
                            "description": "Info if `<img>` uses a legacy format (`.jpg`, `.png`, `.gif`) — suggests WebP/AVIF.",
                            "type": "boolean"
                        },
                        "info_missing_srcset": {
                            "default": true,
                            "description": "Info if `<img>` has no `srcset` (no responsive image markup).",
                            "type": "boolean"
                        },
                        "warn_missing_lazy": {
                            "default": true,
                            "description": "Warn if `<img>` beyond the first on a page has no `loading` attribute.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "js_bloat": {
                    "additionalProperties": false,
                    "description": "Client-side JavaScript bloat detection per route.",
                    "properties": {
                        "enabled": {
                            "default": false,
                            "description": "Enable JS bloat detection.",
                            "type": "boolean"
                        },
                        "max_kb": {
                            "default": 100,
                            "description": "Warn when a route's total local JS exceeds this size in KB.",
                            "type": "number"
                        }
                    },
                    "type": "object"
                },
                "links": {
                    "additionalProperties": false,
                    "description": "Internal link consistency checks.",
                    "properties": {
                        "check_fragments": {
                            "default": false,
                            "description": "Validate that `#fragment` targets exist in the linked page.",
                            "type": "boolean"
                        },
                        "check_internal": {
                            "default": true,
                            "description": "Check that internal links resolve to existing pages.",
                            "type": "boolean"
                        },
                        "check_mixed_content": {
                            "default": true,
                            "description": "Warn on `http://` in internal links (mixed content).",
                            "type": "boolean"
                        },
                        "detect_orphan_pages": {
                            "default": false,
                            "description": "Warn about pages with no incoming internal links (orphan pages).",
                            "type": "boolean"
                        },
                        "fail_on_broken": {
                            "default": true,
                            "description": "Broken internal links are errors (not just warnings).",
                            "type": "boolean"
                        },
                        "forbid_query_params_internal": {
                            "default": true,
                            "description": "Warn on query parameters (`?foo=bar`) in internal links.",
                            "type": "boolean"
                        },
                        "max_url_depth": {
                            "description": "Warn when a page's URL nesting depth (path segments) exceeds this value. Disabled when unset.",
                            "type": "number"
                        }
                    },
                    "type": "object"
                },
                "opengraph": {
                    "additionalProperties": false,
                    "description": "Open Graph and Twitter Card meta tag checks.",
                    "properties": {
                        "check_image_dimensions": {
                            "default": false,
                            "description": "Warn if a local `og:image` is below the recommended 1200x630 dimensions.",
                            "type": "boolean"
                        },
                        "check_image_exists": {
                            "default": false,
                            "description": "Verify that a local `og:image` (own domain or relative) exists in `dist/`.",
                            "type": "boolean"
                        },
                        "og_image_absolute_url": {
                            "default": true,
                            "description": "Error if `og:image` is a relative URL (must be absolute for social sharing).",
                            "type": "boolean"
                        },
                        "og_image_max_size_kb": {
                            "description": "Warn if a local `og:image` file exceeds this size in KB. Disabled when unset.",
                            "type": "number"
                        },
                        "og_title_consistency": {
                            "default": false,
                            "description": "Warn when `og:title` and `<title>` differ significantly in length.",
                            "type": "boolean"
                        },
                        "require_og_description": {
                            "default": false,
                            "description": "Require `og:description` meta tag.",
                            "type": "boolean"
                        },
                        "require_og_image": {
                            "default": false,
                            "description": "Require `og:image` meta tag.",
                            "type": "boolean"
                        },
                        "require_og_title": {
                            "default": false,
                            "description": "Require `og:title` meta tag.",
                            "type": "boolean"
                        },
                        "require_og_type": {
                            "default": false,
                            "description": "Require `og:type` meta tag (e.g. `\"website\"`, `\"article\"`).",
                            "type": "boolean"
                        },
                        "require_og_url": {
                            "default": false,
                            "description": "Require `og:url` canonical property.",
                            "type": "boolean"
                        },
                        "require_twitter_card": {
                            "default": false,
                            "description": "Require `twitter:card` meta tag.",
                            "type": "boolean"
                        },
                        "require_twitter_image": {
                            "default": false,
                            "description": "Require `twitter:image` meta tag.",
                            "type": "boolean"
                        },
                        "twitter_card_valid_values": {
                            "default": true,
                            "description": "Validate `twitter:card` value against the allowed set (`summary`, `summary_large_image`, `app`, `player`).",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "privacy_security": {
                    "additionalProperties": false,
                    "description": "Static privacy and security posture audit (third-party, SRI, CSP readiness, consent indicators).",
                    "properties": {
                        "enabled": {
                            "default": false,
                            "description": "Enable privacy/security checks in dist output.",
                            "type": "boolean"
                        },
                        "gdpr": {
                            "default": false,
                            "description": "Enable GDPR/DSGVO third-party transfer checks (Google Fonts, YouTube, Maps, public CDNs, external images).",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "redirects": {
                    "additionalProperties": false,
                    "description": "Static meta-refresh redirect analysis (links to redirects, chains, loops).",
                    "properties": {
                        "enabled": {
                            "default": false,
                            "description": "Enable redirect analysis in dist output.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "render_blocking": {
                    "additionalProperties": false,
                    "description": "Static render-blocking audit for critical resources and connection hints.",
                    "properties": {
                        "enabled": {
                            "default": false,
                            "description": "Enable render-blocking checks in dist output.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "robots_meta": {
                    "additionalProperties": false,
                    "description": "Robots meta tag checks.",
                    "properties": {
                        "allow_noindex": {
                            "default": true,
                            "description": "Don't warn on pages with `noindex`.",
                            "type": "boolean"
                        },
                        "fail_if_noindex": {
                            "default": false,
                            "description": "Treat any `noindex` page as an error.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "robots_txt": {
                    "additionalProperties": false,
                    "description": "`robots.txt` file checks.",
                    "properties": {
                        "ai_bot_policy": {
                            "default": false,
                            "description": "Warn if AI citation bots (GPTBot, ClaudeBot, PerplexityBot) are blocked.",
                            "type": "boolean"
                        },
                        "check_disallow_all": {
                            "default": true,
                            "description": "Error if `User-agent: *` with `Disallow: /` blocks all crawlers.",
                            "type": "boolean"
                        },
                        "check_noindex_contradiction": {
                            "default": false,
                            "description": "Error when a page is `Disallow`'d in robots.txt yet also has a `noindex` meta tag.",
                            "type": "boolean"
                        },
                        "check_sitemap_blocked": {
                            "default": false,
                            "description": "Warn when a URL listed in the sitemap is blocked by robots.txt.",
                            "type": "boolean"
                        },
                        "max_crawl_delay": {
                            "default": 10,
                            "description": "Warn if `Crawl-delay` exceeds this value in seconds (0 = disabled).",
                            "type": "number"
                        },
                        "require": {
                            "default": false,
                            "description": "`robots.txt` must exist.",
                            "type": "boolean"
                        },
                        "require_sitemap_link": {
                            "default": false,
                            "description": "`robots.txt` must contain a link to the sitemap.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "security": {
                    "additionalProperties": false,
                    "description": "Security heuristic checks.",
                    "properties": {
                        "check_mixed_content": {
                            "default": true,
                            "description": "Warn on `http://` resource URLs (mixed content).",
                            "type": "boolean"
                        },
                        "check_target_blank": {
                            "default": true,
                            "description": "Warn on `target=\"_blank\"` without `rel=\"noopener\"`.",
                            "type": "boolean"
                        },
                        "warn_inline_scripts": {
                            "default": false,
                            "description": "Warn on inline `<script>` tags.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "severity": {
                    "$ref": "#/definitions/Record%3Cstring%2C%22error%22%7C%22warning%22%7C%22info%22%7C%22off%22%3E",
                    "description": "Override severity per rule ID."
                },
                "site": {
                    "additionalProperties": false,
                    "description": "Site-level settings.",
                    "properties": {
                        "base_url": {
                            "description": "Base URL for canonical/sitemap checks. Also settable via `site` option or Astro's `site` config.",
                            "type": "string"
                        }
                    },
                    "type": "object"
                },
                "sitemap": {
                    "additionalProperties": false,
                    "description": "Sitemap cross-reference checks.",
                    "properties": {
                        "canonical_must_be_in_sitemap": {
                            "default": true,
                            "description": "Canonical URLs should appear in the sitemap.",
                            "type": "boolean"
                        },
                        "entries_must_exist_in_dist": {
                            "default": true,
                            "description": "Every sitemap URL must correspond to a page in `dist/`.",
                            "type": "boolean"
                        },
                        "forbid_noncanonical_in_sitemap": {
                            "default": false,
                            "description": "Sitemap must not contain non-canonical URLs.",
                            "type": "boolean"
                        },
                        "require": {
                            "default": false,
                            "description": "`sitemap.xml` must exist in `dist/`.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "structured_data": {
                    "additionalProperties": false,
                    "description": "Structured data (JSON-LD) validation.",
                    "properties": {
                        "check_json_ld": {
                            "default": false,
                            "description": "Validate JSON-LD syntax and semantics (`@context`, `@type`, required properties).",
                            "type": "boolean"
                        },
                        "detect_duplicate_types": {
                            "default": false,
                            "description": "Warn if a page has multiple JSON-LD blocks with the same `@type`.",
                            "type": "boolean"
                        },
                        "require_json_ld": {
                            "default": false,
                            "description": "Every page must contain at least one JSON-LD block.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "structured_data_graph": {
                    "additionalProperties": false,
                    "description": "Cross-page structured-data graph consistency checks.",
                    "properties": {
                        "enabled": {
                            "default": false,
                            "description": "Enable cross-page JSON-LD consistency checks in dist output.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "url_normalization": {
                    "additionalProperties": false,
                    "description": "URL normalization rules for internal link and canonical consistency.",
                    "properties": {
                        "index_html": {
                            "default": "forbid",
                            "description": "Whether `index.html` in URLs is allowed. `\"forbid\"`: warn on `/page/index.html` links, `\"allow\"`: permit them.",
                            "enum": [
                                "allow",
                                "forbid"
                            ],
                            "type": "string"
                        },
                        "trailing_slash": {
                            "default": "always",
                            "description": "Trailing slash policy. `\"always\"`: require trailing slash, `\"never\"`: forbid, `\"ignore\"`: no check.",
                            "enum": [
                                "always",
                                "ignore",
                                "never"
                            ],
                            "type": "string"
                        }
                    },
                    "type": "object"
                },
                "ux_heuristics": {
                    "additionalProperties": false,
                    "default": false,
                    "description": "UX heuristic checks — CTA clarity, trust signals, cognitive load.",
                    "properties": {
                        "enabled": {
                            "default": false,
                            "description": "Enable UX heuristics module.",
                            "type": "boolean"
                        },
                        "max_links_per_page": {
                            "default": 80,
                            "description": "Warn if a page exceeds this many links (cognitive load).",
                            "type": "number"
                        },
                        "min_cta_per_page": {
                            "default": 1,
                            "description": "Warn if a page has fewer than this many CTA-like elements.",
                            "type": "number"
                        }
                    },
                    "type": "object"
                }
            },
            "type": "object"
        }
    },
    "properties": {
        "aiVisibility": {
            "default": false,
            "description": "Enable AI visibility scoring. Checks static signals (word count, schema, OG tags, semantic HTML)\nthat influence how AI search systems (Perplexity, ChatGPT Search, Claude) cite your content.\nPass `true` to enable with defaults, or an object for fine-grained control.",
            "type": "boolean"
        },
        "baseline": {
            "description": "Path to a baseline file (relative to project root). When set, only findings that are\n*new* since the baseline was written will be reported. If the file does not exist,\na warning is logged and the audit runs normally.",
            "type": "string"
        },
        "benchmark": {
            "description": "Print per-check timing benchmarks in the output.",
            "type": "boolean"
        },
        "debug": {
            "default": false,
            "description": "Verbose diagnostics on stderr: the resolved config (after preset merge),\ndiscovery stats (files found / excluded by filters / parsed, sitemap status),\nand per-check finding counts + timings. Never touches the report on stdout.\nReplaces the progress bar when enabled.",
            "type": "boolean"
        },
        "disable": {
            "description": "Disable the integration (useful for dev mode).",
            "type": "boolean"
        },
        "failOn": {
            "description": "Build fail strategy. `'errors'`: fail on errors only (default when `throwOnError` is true).\n`'warnings'`: fail on any finding (implies `strict`). `'never'`: never fail the build.",
            "enum": [
                "errors",
                "never",
                "warnings"
            ],
            "type": "string"
        },
        "goLive": {
            "$ref": "#/definitions/GoLiveConfig",
            "description": "Production readiness gate. Catches staging/dev leftovers before a build goes live.\nUse `process.env.DEPLOY_CONTEXT === \"production\"` to enable only in production."
        },
        "groups": {
            "$ref": "#/definitions/GroupsConfig",
            "description": "Shorthand rule groups. `true` enables the group, `\"warn\"` enables but downgrades all findings to warnings."
        },
        "hints": {
            "additionalProperties": false,
            "description": "Heuristic hints for source file locations in Content Collections / MDX projects.",
            "properties": {
                "sourceFiles": {
                    "default": false,
                    "description": "Show likely source file paths next to dist/ findings. Heuristic — may not always match.",
                    "type": "boolean"
                }
            },
            "type": "object"
        },
        "maxErrors": {
            "description": "Maximum number of errors before aborting.",
            "type": "number"
        },
        "maxWarnings": {
            "description": "Fail the build if the warning count exceeds this number.",
            "type": "number"
        },
        "output": {
            "description": "Write the JSON report to this file path (relative to project root).",
            "type": "string"
        },
        "outputMarkdown": {
            "description": "Write a Markdown summary report to this file path (relative to project root).",
            "type": "string"
        },
        "pageOverview": {
            "description": "Show page properties overview instead of running checks.",
            "type": "boolean"
        },
        "preset": {
            "description": "Preset to apply before user overrides. `\"strict\"` enables all checks, `\"relaxed\"` is lenient.",
            "enum": [
                "accessibility",
                "performance",
                "production",
                "relaxed",
                "seo",
                "standard",
                "strict"
            ],
            "type": "string"
        },
        "progress": {
            "description": "Show a live progress bar on stderr while checks run.\nDefaults to auto: on in an interactive terminal, silent in CI.\nSet `true`/`false` to force, or `'verbose'` to print each check as its\nown line with findings count and timing instead of an animated bar.",
            "enum": [
                false,
                true,
                "verbose"
            ]
        },
        "reports": {
            "$ref": "#/definitions/ReportsConfig",
            "description": "Write one or more report files. Supports `json`, `markdown`, and `sarif` (SARIF 2.1.0) formats.\nMultiple formats can be active simultaneously. Takes precedence over `output`/`outputMarkdown` when both are set."
        },
        "rules": {
            "$ref": "#/definitions/RulesConfig",
            "description": "Inline rules config — all check settings go here."
        },
        "site": {
            "description": "Base URL (auto-detected from Astro's `site` config if not set).",
            "type": "string"
        },
        "strict": {
            "description": "Treat warnings as errors.",
            "type": "boolean"
        },
        "throwOnError": {
            "description": "Throw an error when the audit finds issues (fails the build). Default: false",
            "type": "boolean"
        },
        "uxHeuristics": {
            "anyOf": [
                {
                    "additionalProperties": false,
                    "properties": {
                        "maxLinksPerPage": {
                            "type": "number"
                        },
                        "minCtaPerPage": {
                            "type": "number"
                        }
                    },
                    "type": "object"
                },
                {
                    "type": "boolean"
                }
            ],
            "default": false,
            "description": "Enable UX heuristic checks. Evaluates CTA clarity, trust signals, and cognitive load.\nPass `true` to enable with defaults, or an object for fine-grained control."
        },
        "writeBaseline": {
            "description": "Write current findings as the new baseline and exit with code 0.\nUse this once to adopt the plugin on a site with existing issues.",
            "type": "boolean"
        }
    },
    "type": "object"
}

